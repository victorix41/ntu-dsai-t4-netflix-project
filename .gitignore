# Python cache
__pycache__/
*.pyc

# Virtual environments
.venv/
venv/

# Environment variables and secrets
.env
.env.*
!.env.example

# Kaggle credentials
kaggle.json

# Google Cloud credentials / keys
*service-account*.json
*credentials*.json
*key*.json

# Local raw data files
data/raw/*
!data/raw/.gitkeep

# Downloaded compressed files
*.zip

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# OS/editor files
.DS_Store
.vscode/

# .streamlit/secrets.toml is used for storing sensitive information like API keys and credentials. Not for version control.
.streamlit/secrets.toml

# ntu-dsai-netflix-runner-key.json is a specific file that contains sensitive credentials for the Netflix project. It should be ignored to prevent accidental exposure of sensitive information.
ntu-dsai-netflix-runner-key.json
*:Zone.Identifier

# ==========================================
# dbt Exclusion Targets (Industry Standards)
# ==========================================
# Exclude dynamically generated compilation targets
target/

# Exclude third-party dependency packages managed by dbt
dbt_modules/
packages/

# Exclude local developer-specific configuration files
*.user.yml

# ==========================================
# Dagster & Environment Exclusion Targets
# ==========================================
# Exclude python cache files
__pycache__/
*.pyc

# Exclude localized tracking logs generated by our asset functions
netflix_dagster/headless_execution.log
netflix_dagster/pipeline_logs/

# Exclude localized configuration environmental secret variables
.env

# Exclude raw local dataset files
netflix_dagster/data/