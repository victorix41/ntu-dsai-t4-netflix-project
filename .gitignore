# Python cache
__pycache__/
*.pyc

# Virtual environments
.venv/
venv/

# Environment variables and secrets
.env
.env.*
!.env.example

# Kaggle credentials
kaggle.json

# Google Cloud credentials / keys
*service-account*.json
*credentials*.json
*key*.json

# Local raw data files
data/raw/*
!data/raw/.gitkeep

# Downloaded compressed files
*.zip

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# OS/editor files
.DS_Store
.vscode/

# .streamlit/secrets.toml is used for storing sensitive information like API keys and credentials. Not for version control.
.streamlit/secrets.toml

# ntu-dsai-netflix-runner-key.json is a specific file that contains sensitive credentials for the Netflix project. It should be ignored to prevent accidental exposure of sensitive information.
ntu-dsai-netflix-runner-key.json
